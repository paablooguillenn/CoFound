# Variables usadas por docker-compose.yml.
# Copia este archivo a .env (no se commitea) y pon tus claves reales.

# Groq API key para el servicio de IA del backend.
# Obtén la tuya en https://console.groq.com/keys
GROQ_API_KEY=

# Resend API key para enviar emails (códigos de recuperación de contraseña).
# Crea cuenta gratis en https://resend.com (3000 emails/mes free).
# Si lo dejas vacío, los emails se imprimen en los logs del backend (modo dev).
RESEND_API_KEY=

# Remitente que aparece en los emails. Por defecto usa el dominio de pruebas de Resend.
# Para producción, verifica tu propio dominio en Resend.
EMAIL_FROM=CoFound <onboarding@resend.dev>
